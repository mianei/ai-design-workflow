# AI Design Workflow Agent — environment template
# Copy to .env and fill in keys. Without keys, the app runs in mock mode.

# openai | anthropic | kimi | moonshot | mock
LLM_PROVIDER=kimi
# 常用：kimi-k3 / kimi-k2.5 / moonshot-v1-8k / moonshot-v1-32k
LLM_MODEL=kimi-k3
LLM_TIMEOUT_SECONDS=120
PIPELINE_AGENT_TIMEOUT_SECONDS=300

# Kimi / Moonshot（国内）
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# 可选：OpenAI / Anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_BASE_URL=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
